# copilot_write_secret_exfil.rules — GitHub Copilot secret exfiltration protection.
# Technology: copilot | Capability: write
# Covers: CamoLeak invisible Unicode (CVSS 9.6), credential suggestions from training,
# encoded URL exfiltration, dynamic imports, and dangerous eval/innerHTML patterns.

rule no-copilot-zero-width-with-network {
  enabled true
  priority 100
  severity error
  DENY write
  IF content REGEX "\\\\u200[b-f]" AND content CONTAINS "http"
  OR content REGEX "\\\\u200[b-f]" AND content CONTAINS "fetch"
  OR content REGEX "\\\\u200[b-f]" AND content CONTAINS "curl"
  OR content REGEX "\\\\ufeff" AND content CONTAINS "http"
  MESSAGE "CamoLeak (CVSSv3 9.6, June 2025): zero-width Unicode characters combined with HTTP/fetch calls silently exfiltrate secrets and source code from private repos. This attack uses Copilot Chat's trust in GitHub's own infrastructure to bypass CSP. Writing code with invisible Unicode plus network calls is blocked."
}

rule no-copilot-credential-suggestion {
  enabled true
  priority 95
  severity error
  DENY write
  IF content LINE_REGEX "(api_key|apiKey|API_KEY)\\s*[:=]\\s*['\"][A-Za-z0-9+/_-]{20,}['\"]"
  OR content LINE_REGEX "(password|passwd|pwd)\\s*[:=]\\s*['\"][^'\"]{8,}['\"]"
  OR content LINE_REGEX "(secret|token)\\s*[:=]\\s*['\"][A-Za-z0-9+/_-]{20,}['\"]"
  MESSAGE "Copilot credential suggestion from training data. Research (Chinese University of Hong Kong) built an algorithm that extracts real secrets from Copilot suggestions — the model memorizes credentials from training data and suggests them in completions. Never accept suggested credential values. Use environment variables."
}

rule ask-copilot-base64-encoded-url {
  enabled true
  priority 85
  severity warning
  ASK write
  IF content LINE_REGEX "atob\\s*\\(" AND content CONTAINS "http"
  OR content LINE_REGEX "Buffer\\.from\\s*\\([^)]*['\"]base64['\"]\\)" AND content CONTAINS "http"
  OR content LINE_REGEX "b64decode\\s*\\(" AND content CONTAINS "http"
  OR content LINE_REGEX "base64\\.b64decode\\s*\\(" AND content CONTAINS "fetch"
  MESSAGE "Base64-decoded URL in Copilot-generated code. CamoLeak-style attacks encode exfiltration endpoints in base64 to bypass visual inspection and CSP analysis. Decode and verify the URL before accepting this suggestion."
  PROMPT "Decode the base64 string and verify the URL points to a trusted endpoint. CamoLeak (CVSS 9.6) hides malicious exfiltration URLs using encoding to bypass visual inspection of code review."
}

rule ask-copilot-dynamic-module-load {
  enabled true
  priority 80
  severity warning
  ASK write
  IF content LINE_REGEX "import\\s*\\([^)]*\\+[^)]*\\)"
  OR content LINE_REGEX "require\\s*\\([^)]*\\+[^)]*\\)"
  OR content LINE_REGEX "__import__\\s*\\([^)]*\\+[^)]*\\)"
  OR content LINE_REGEX "importlib\\.import_module\\s*\\([^)]*\\+[^)]*\\)"
  MESSAGE "Dynamic import with string concatenation in Copilot-generated code. Concatenated import paths can load typosquatted or attacker-controlled packages by constructing package names at runtime — hiding them from static analysis and dependency scanning."
  PROMPT "Is the imported module name fully static? Dynamic imports with concatenation can resolve to typosquatted packages. Verify the complete module name is visible in the source without concatenation."
}

rule log-copilot-dangerous-patterns {
  enabled true
  priority 50
  severity info
  LOG write
  IF content LINE_REGEX "eval\\s*\\("
  OR content LINE_REGEX "new Function\\s*\\("
  OR content CONTAINS "innerHTML"
  OR content CONTAINS "dangerouslySetInnerHTML"
  OR content LINE_REGEX "document\\.write\\s*\\("
  MESSAGE "Copilot suggestion contains high-risk pattern (eval/Function/innerHTML). An ACM study found 29.5% of Copilot-generated Python and 24.2% of JavaScript snippets have security weaknesses. Review these patterns carefully for injection vulnerabilities before accepting."
}
